# Copy to .env (or export as real environment variables on the VPS).

# Long random string — required to view /rsvp, /rsvp/summary, /rsvp/export.csv, /admin
RSVP_ADMIN_TOKEN=change-me-to-a-long-random-string

# Comma-separated list of origins allowed to POST /rsvp (your Vercel domain(s))
RSVP_ALLOWED_ORIGINS=https://brianandchimango.vercel.app,https://brianandchimango.com

# Optional — defaults to server/rsvp.db
# RSVP_DB_PATH=/var/lib/rsvp/rsvp.db
